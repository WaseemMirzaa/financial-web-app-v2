# Copy to .env.local (or .env) and fill with real values. Never commit those files.

# Admin seeding — required for `npm run seed-admin` and `db:seed`
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Demo employee/customer users in `db:seed` (same password for all seeded demo employees and customers)
SEED_DEMO_PASSWORD=

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=financial_app
DB_PORT=3306

# JWT — use a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET=

# Google Translate (server-side only — do not expose in NEXT_PUBLIC_*)
GOOGLE_TRANSLATE_API_KEY=

# Firebase Web (client-safe; restrict key in Google Cloud Console by HTTP referrer)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin / FCM server push (required for mobile + web push from backend)
# Option A — paste full service account JSON (one line, from Firebase Console → Project settings → Service accounts):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Option B — split fields (private_key can use \\n for newlines, or base64):
# FIREBASE_PROJECT_ID=khalij-tamweel-app
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@khalij-tamweel-app.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Option C — path to JSON file on server:
# GOOGLE_APPLICATION_CREDENTIALS=/var/www/financial-web-app/firebase-adminsdk.json

# Chat file uploads — optional absolute path (must be writable by the Node/PM2 user).
# Default if unset: <project>/public/assets
# CHAT_UPLOAD_DIR=/var/www/financial-web-app/public/assets

# App URL / CORS
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# CORS_ORIGIN=https://your-domain.com

# SendGrid (password reset)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@your-domain.com
